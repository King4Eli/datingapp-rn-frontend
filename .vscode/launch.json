{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "npm start",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": [
                "react-native",
                "start"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "build Android",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": [
                "react-native",
                "run-android"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "APK --create",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "cmd.exe",
            "runtimeArgs": [
                "/c",
                "cd android && gradlew assembleRelease && start explorer \"app\\build\\outputs\\apk\\release\""
            ],
            "console": "integratedTerminal", 
        },
        {
            "name": "build IOS",
            "type": "node",
            "request": "launch",
            "runtimeExecutable": "npx",
            "runtimeArgs": [
                "react-native",
                "run-ios"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        
        {
            "name": "_match _convo",
            "type": "node",
            "request": "launch",
            "runtimeArgs": [
                ".vscode/sj/genconvoandmatch/genconvomain.js"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
        {
            "name": "TINDER Scrape",
            "type": "node",
            "request": "launch",
            "runtimeArgs": [
                ".vscode/sj/tinder_scrape/main.mjs"
            ],
            "console": "integratedTerminal",
            "internalConsoleOptions": "neverOpen"
        },
    ]
}
